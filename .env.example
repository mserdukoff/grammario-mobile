EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Learner API (FastAPI etc.): base URL without trailing /api/v1 (app adds /api/v1).
EXPO_PUBLIC_API_URL=http://localhost:8000
# Public site (legal links, default admin host fallback). Also used as Origin/Referer on API calls unless API_CLIENT_ORIGIN is set.
EXPO_PUBLIC_WEB_ORIGIN=https://grammario.ai
# Optional. If your server only allows a specific Origin (e.g. www), set it here for API/admin requests.
# EXPO_PUBLIC_API_CLIENT_ORIGIN=https://grammario.ai
# Optional. Admin dashboard: overrides admin host. If unset, admin uses EXPO_PUBLIC_API_URL + /api/v1 (same as analyze/usage).
# Use when Next.js admin BFF is not the same origin as EXPO_PUBLIC_API_URL.
# EXPO_PUBLIC_ADMIN_API_URL=http://192.168.1.10:3000/api/v1
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com

# Shown in-app only when the signed-in user id matches (UI gate; enforce on server).
ADMIN_USER_ID=3f5a9d50-d8fb-4e05-a7c7-52b79d1aeee5
